# Server
GRPC_PORT=9090
HTTP_PORT=8080

# Database
DATABASE_URL=postgres://rain:rain@localhost:5432/rain_staking?sslmode=disable

# Staking Provider: "mock" or "bitgo"
STAKING_PROVIDER=mock

# BitGo (only required when STAKING_PROVIDER=bitgo)
BITGO_BASE_URL=https://app.bitgo-test.com
BITGO_ACCESS_TOKEN=
BITGO_WALLET_ID=
BITGO_COIN=hteth

# Authentication
JWT_SECRET=dev-secret-do-not-use-in-production

# Reward Poller
REWARD_POLL_INTERVAL=5m

# Logging
LOG_LEVEL=info
